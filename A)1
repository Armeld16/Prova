import networkx as nx
from database.DAO import DAO

class Model:
    def __init__(self):
        self._graph = nx.DiGraph()
        self._idMap = {}
        self._fatMap = {}

    def buildGraph(self, country):
        self._graph.clear()
        self._idMap.clear()
        self._fatMap.clear()
        nodi = DAO.getNodi(country)
        for n in nodi:
            self._idMap[n.CustomerId] = n
        self._graph.add_nodes_from(nodi)
        for cid, fat in DAO.getFatturato(country):
            self._fatMap[cid] = fat
        for id1, id2 in DAO.getArchi(country):
            if id1 not in self._idMap or id2 not in self._idMap:
                continue
            fat1 = self._fatMap.get(id1, 0)
            fat2 = self._fatMap.get(id2, 0)
            peso = fat1 + fat2
            if fat1 > fat2:
                self._graph.add_edge(self._idMap[id1], self._idMap[id2], weight=peso)
            elif fat2 > fat1:
                self._graph.add_edge(self._idMap[id2], self._idMap[id1], weight=peso)
            else:
                self._graph.add_edge(self._idMap[id1], self._idMap[id2], weight=peso)
                self._graph.add_edge(self._idMap[id2], self._idMap[id1], weight=peso)

    def graphDetails(self):
        return len(self._graph.nodes), len(self._graph.edges)

    def getTop5Archi(self):
        return sorted(self._graph.edges(data=True),
                      key=lambda x: x[2]["weight"], reverse=True)[:5]

    def getNumeroComponenti(self):
        return nx.number_weakly_connected_components(self._graph)

    def getMaggioreComponente(self):
        return max(nx.weakly_connected_components(self._graph), key=len)

    def getCountries(self):
        return DAO.getCountries()


