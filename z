from dataclasses import dataclass, field

@dataclass
class Artist:
    ArtistId: int
    Name: str
    tracks: list = field(default_factory=list)
    playlists: set = field(default_factory=set)

    def __hash__(self): return hash(self.ArtistId)
    def __eq__(self, other): return self.ArtistId == other.ArtistId
    def __str__(self): return self.Name if self.Name else ""


