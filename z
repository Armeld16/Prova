import networkx as nx
from database.DAO import DAO

class Model:
    def __init__(self):
        self._graph = nx.Graph()
        self._idMap = {}

    def buildGraph(self):
        self._graph.clear()
        self._idMap.clear()
        nodi = DAO.getAllArtists()
        for n in nodi:
            self._idMap[n.ArtistId] = n
        self._graph.add_nodes_from(nodi)
        for aid, tid in DAO.getAllTracks():
            if aid in self._idMap:
                self._idMap[aid].tracks.append(tid)
        for aid, pid in DAO.getAllPlaylists():
            if aid in self._idMap:
                self._idMap[aid].playlists.add(pid)
        for id1, id2, peso in DAO.getArchi():
            if id1 in self._idMap and id2 in self._idMap:
                self._graph.add_edge(
                    self._idMap[id1], self._idMap[id2], weight=peso)

    def graphDetails(self):
        return len(self._graph.nodes), len(self._graph.edges)

    def getArtistaMaggioreGrado(self):
        return max(self._graph.nodes(),
                   key=lambda n: self._graph.degree(n))

    def getArtistaMassimaPesatura(self):
        best, bestScore = None, None
        for v in self._graph.nodes():
            score = sum(d["weight"]
                        for _, _, d in self._graph.edges(v, data=True))
            if bestScore is None or score > bestScore:
                bestScore, best = score, v
        return best, bestScore

    def getTop10Archi(self):
        return sorted(
            self._graph.edges(data=True),
            key=lambda x: (-x[2]["weight"],
                           x[0].Name if x[0].Name else "",
                           x[1].Name if x[1].Name else ""))[:10]

    def getNumeroComponenti(self):
        return nx.number_connected_components(self._graph)

    def getMaggioreComponente(self):
        return max(nx.connected_components(self._graph), key=len)

    def getAllNodes(self):
        return self._graph.nodes()


