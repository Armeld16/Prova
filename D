import networkx as nx
from itertools import combinations
from database.DAO import DAO

class Model:
    def __init__(self):
        self._graph = nx.Graph()
        self._idMap = {}
        self._speseMap = {}

    def buildGraph(self, country, genre):
        self._graph.clear()
        self._idMap.clear()
        self._speseMap.clear()
        nodi = DAO.getNodi(country)
        for n in nodi:
            self._idMap[n.CustomerId] = n
        self._graph.add_nodes_from(nodi)
        for cid, spesa in DAO.getNodiAttivi(country, genre):
            self._speseMap[cid] = spesa
        attivi = list(self._speseMap.keys())
        for i in range(len(attivi)):
            for j in range(i+1, len(attivi)):
                a, b = attivi[i], attivi[j]
                peso = self._speseMap[a] + self._speseMap[b]
                self._graph.add_edge(self._idMap[a], self._idMap[b], weight=peso)

    def graphDetails(self):
        return len(self._graph.nodes), len(self._graph.edges)

    def getTop3Archi(self):
        return sorted(self._graph.edges(data=True),
                      key=lambda x: x[2]["weight"], reverse=True)[:3]

    def getNumeroComponenti(self):
        return nx.number_connected_components(self._graph)

    def getMaggioreOrdinata(self):
        largest = max(nx.connected_components(self._graph), key=len)
        ordinati = sorted(largest,
                          key=lambda n: self._speseMap.get(n.CustomerId, 0),
                          reverse=True)
        return [(n, self._speseMap.get(n.CustomerId, 0)) for n in ordinati]

    def getCountries(self):
        return DAO.getCountries()

    def getGenres(self):
        return DAO.getGenres()


