from database.DB_connect import DBConnect
from model.customer import Customer

class DAO():

    @staticmethod
    def getCountries():
        conn = DBConnect.get_connection()
        cursor = conn.cursor(dictionary=True)
        query = """SELECT DISTINCT Country FROM Customer
                   WHERE Country IS NOT NULL ORDER BY Country ASC"""
        cursor.execute(query)
        res = [row["Country"] for row in cursor]
        cursor.close(); conn.close()
        return res

    @staticmethod
    def getGenres():
        conn = DBConnect.get_connection()
        cursor = conn.cursor(dictionary=True)
        query = "SELECT Name FROM Genre ORDER BY Name ASC"
        cursor.execute(query)
        res = [row["Name"] for row in cursor]
        cursor.close(); conn.close()
        return res

    @staticmethod
    def getNodi(country):
        conn = DBConnect.get_connection()
        cursor = conn.cursor(dictionary=True)
        query = "SELECT * FROM Customer WHERE Country = %s"
        cursor.execute(query, (country,))
        res = [Customer(**row) for row in cursor]
        cursor.close(); conn.close()
        return res

    @staticmethod
    def getNodiAttivi(country, genre):
        conn = DBConnect.get_connection()
        cursor = conn.cursor(dictionary=True)
        query = """
            SELECT c.CustomerId, SUM(i2.Total) AS spesa_totale
            FROM Customer c, Invoice i2
            WHERE c.Country = %s
            AND c.CustomerId = i2.CustomerId
            AND c.CustomerId IN (
                SELECT DISTINCT c2.CustomerId
                FROM Customer c2, Invoice i, InvoiceLine il, Track t, Genre g
                WHERE c2.CustomerId = i.CustomerId
                AND i.InvoiceId = il.InvoiceId
                AND il.TrackId = t.TrackId
                AND t.GenreId = g.GenreId
                AND g.Name = %s
            )
            GROUP BY c.CustomerId
        """
        cursor.execute(query, (country, genre))
        res = [(row["CustomerId"], row["spesa_totale"]) for row in cursor]
        cursor.close(); conn.close()
        return res


