import flet as ft

class Controller:
    def __init__(self, view, model):
        self._view = view
        self._model = model

    def handleCreaGrafo(self, e):
        country = self._view._ddCountry.value
        genre = self._view._ddGenre.value
        if country is None:
            self._view.txt_result.controls.clear()
            self._view.txt_result.controls.append(ft.Text("Selezionare un paese", color="red"))
            self._view.update_page(); return
        if genre is None:
            self._view.txt_result.controls.clear()
            self._view.txt_result.controls.append(ft.Text("Selezionare un genere", color="red"))
            self._view.update_page(); return
        self._model.buildGraph(country, genre)
        nodi, archi = self._model.graphDetails()
        self._view.txt_result.controls.clear()
        self._view.txt_result.controls.append(ft.Text(f"Numero di nodi: {nodi}"))
        self._view.txt_result.controls.append(ft.Text(f"Numero di archi: {archi}"))
        top3 = self._model.getTop3Archi()
        self._view.txt_result.controls.append(ft.Text("I 3 archi di peso maggiore:"))
        for a in top3:
            self._view.txt_result.controls.append(
                ft.Text(f"{a[0]} <-> {a[1]} | peso = {a[2]['weight']:.2f}"))
        n = self._model.getNumeroComponenti()
        self._view.txt_result.controls.append(ft.Text(f"Numero di componenti connesse: {n}"))
        self._view.update_page()

    def handleDettagliComponente(self, e):
        if len(self._model._graph.nodes) == 0:
            self._view.txt_result.controls.append(ft.Text("Creare prima il grafo", color="red"))
            self._view.update_page(); return
        lista = self._model.getMaggioreOrdinata()
        self._view.txt_result.controls.append(ft.Text("Componente piu grande:"))
        for nodo, spesa in lista:
            self._view.txt_result.controls.append(
                ft.Text(f"{nodo.FirstName} {nodo.LastName} -- spesa: {spesa:.2f}"))
        self._view.update_page()

    def fillDD(self):
        for c in self._model.getCountries():
            self._view._ddCountry.options.append(ft.dropdown.Option(c))
        for g in self._model.getGenres():
            self._view._ddGenre.options.append(ft.dropdown.Option(g))
        self._view.update_page()
