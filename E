from database.DB_connect import DBConnect
from model.artist import Artist

class DAO():

    @staticmethod
    def getGenres():
        conn = DBConnect.get_connection()
        cursor = conn.cursor(dictionary=True)
        query = "SELECT DISTINCT Name FROM Genre ORDER BY Name ASC"
        cursor.execute(query)
        res = [row["Name"] for row in cursor]
        cursor.close(); conn.close()
        return res

    @staticmethod
    def getNodi(genre):
        conn = DBConnect.get_connection()
        cursor = conn.cursor(dictionary=True)
        query = """
            SELECT DISTINCT a.ArtistId, a.Name
            FROM Artist a, Album al, Track t, Genre g
            WHERE a.ArtistId = al.ArtistId
            AND al.AlbumId = t.AlbumId
            AND t.GenreId = g.GenreId
            AND g.Name = %s
        """
        cursor.execute(query, (genre,))
        res = [Artist(**row) for row in cursor]
        cursor.close(); conn.close()
        return res

    @staticmethod
    def getPopolarita(genre):
        conn = DBConnect.get_connection()
        cursor = conn.cursor(dictionary=True)
        query = """
            SELECT a.ArtistId, SUM(il.Quantity) AS pop
            FROM Artist a, Album al, Track t, Genre g, InvoiceLine il
            WHERE a.ArtistId = al.ArtistId
            AND al.AlbumId = t.AlbumId
            AND t.GenreId = g.GenreId
            AND g.Name = %s
            AND il.TrackId = t.TrackId
            GROUP BY a.ArtistId
        """
        cursor.execute(query, (genre,))
        res = [(row["ArtistId"], row["pop"]) for row in cursor]
        cursor.close(); conn.close()
        return res

    @staticmethod
    def getArchi(genre):
        conn = DBConnect.get_connection()
        cursor = conn.cursor(dictionary=True)
        query = """
            SELECT DISTINCT al1.ArtistId AS id1, al2.ArtistId AS id2
            FROM Invoice i,
                 InvoiceLine il1, Track t1, Album al1, Genre g1,
                 InvoiceLine il2, Track t2, Album al2, Genre g2
            WHERE il1.InvoiceId = i.InvoiceId
            AND il2.InvoiceId = i.InvoiceId
            AND il1.TrackId = t1.TrackId
            AND t1.AlbumId = al1.AlbumId
            AND t1.GenreId = g1.GenreId
            AND g1.Name = %s
            AND il2.TrackId = t2.TrackId
            AND t2.AlbumId = al2.AlbumId
            AND t2.GenreId = g2.GenreId
            AND g2.Name = %s
            AND al1.ArtistId < al2.ArtistId
        """
        cursor.execute(query, (genre, genre))
        res = [(row["id1"], row["id2"]) for row in cursor]
        cursor.close(); conn.close()
        return res


