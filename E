import networkx as nx
from database.DAO import DAO

class Model:
    def __init__(self):
        self._graph = nx.DiGraph()
        self._idMap = {}
        self._popMap = {}

    def buildGraph(self, genre):
        self._graph.clear()
        self._idMap.clear()
        self._popMap.clear()
        nodi = DAO.getNodi(genre)
        for n in nodi:
            self._idMap[n.ArtistId] = n
        self._graph.add_nodes_from(nodi)
        for aid, pop in DAO.getPopolarita(genre):
            self._popMap[aid] = pop
        for id1, id2 in DAO.getArchi(genre):
            if id1 not in self._idMap or id2 not in self._idMap:
                continue
            pop1 = self._popMap.get(id1, 0)
            pop2 = self._popMap.get(id2, 0)
            peso = pop1 + pop2
            if pop1 > pop2:
                self._graph.add_edge(self._idMap[id1], self._idMap[id2], weight=peso)
            elif pop2 > pop1:
                self._graph.add_edge(self._idMap[id2], self._idMap[id1], weight=peso)
            else:
                self._graph.add_edge(self._idMap[id1], self._idMap[id2], weight=peso)
                self._graph.add_edge(self._idMap[id2], self._idMap[id1], weight=peso)

    def graphDetails(self):
        return len(self._graph.nodes), len(self._graph.edges)

    def getTop5Archi(self):
        return sorted(self._graph.edges(data=True),
                      key=lambda x: x[2]["weight"], reverse=True)[:5]

    def getArtistaMigliore(self):
        best, bestScore = None, None
        for v in self._graph.nodes():
            out = sum(d["weight"] for _, _, d in self._graph.out_edges(v, data=True))
            inn = sum(d["weight"] for _, _, d in self._graph.in_edges(v, data=True))
            score = out - inn
            if bestScore is None or score > bestScore:
                bestScore, best = score, v
        return best, bestScore

    def getGenres(self):
        return DAO.getGenres()


