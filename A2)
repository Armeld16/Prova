from dataclasses import dataclass, field

@dataclass
class Album:
    AlbumId: int
    Title: str
    ArtistId: int
    tracks: list = field(default_factory=list)

    def __hash__(self): return hash(self.AlbumId)
    def __eq__(self, other): return self.AlbumId == other.AlbumId
    def __str__(self): return self.Title


