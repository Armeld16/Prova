import networkx as nx
from database.DAO import DAO

class Model:
    def __init__(self):
        self._graph = nx.Graph()
        self._idMap = {}

    def buildGraph(self):
        self._graph.clear()
        self._idMap.clear()
        nodi = DAO.getAllAlbums()
        for n in nodi:
            self._idMap[n.AlbumId] = n
            n.tracks = DAO.getTracce(n.AlbumId)
        self._graph.add_nodes_from(nodi)
        for id1, id2 in DAO.getArchi():
            if id1 in self._idMap and id2 in self._idMap:
                self._graph.add_edge(self._idMap[id1], self._idMap[id2])

    def graphDetails(self):
        return len(self._graph.nodes), len(self._graph.edges)

    def getNumeroComponenti(self):
        return nx.number_connected_components(self._graph)

    def getMaggioreComponente(self):
        return max(nx.connected_components(self._graph), key=len)

    def getComponenteAlbum(self, albumId):
        source = self._idMap[int(albumId)]
        return nx.node_connected_component(self._graph, source)

    def getAlbumConKBrani(self, componente, k):
        return sorted(
            [n for n in componente if len(n.tracks) >= k],
            key=lambda n: len(n.tracks), reverse=True)

    def getAllNodes(self):
        return self._graph.nodes()


