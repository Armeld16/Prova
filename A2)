import flet as ft

class Controller:
    def __init__(self, view, model):
        self._view = view
        self._model = model

    def handleCreaGrafo(self, e):
        self._model.buildGraph()
        nodi, archi = self._model.graphDetails()
        self._view.txt_result.controls.clear()
        self._view.txt_result.controls.append(ft.Text("Grafo correttamente creato."))
        self._view.txt_result.controls.append(ft.Text(f"Numero di nodi: {nodi}"))
        self._view.txt_result.controls.append(ft.Text(f"Numero di archi: {archi}"))
        # popola dropdown album
        self._view._ddAlbum.options.clear()
        for n in self._model.getAllNodes():
            self._view._ddAlbum.options.append(ft.dropdown.Option(n.AlbumId, n.Title))
        self._view.update_page()

    def handleStampaInfo(self, e):
        if len(self._model._graph.nodes) == 0:
            self._view.txt_result.controls.append(ft.Text("Creare prima il grafo", color="red"))
            self._view.update_page(); return
        n = self._model.getNumeroComponenti()
        maggiore = self._model.getMaggioreComponente()
        self._view.txt_result.controls.append(
            ft.Text(f"Numero componenti connesse: {n}"))
        self._view.txt_result.controls.append(
            ft.Text(f"Componente più grande ({len(maggiore)} nodi):"))
        for nodo in maggiore:
            self._view.txt_result.controls.append(ft.Text(f"{nodo}"))
        self._view.update_page()

    def handleTrovaSelezione(self, e):
        albumId = self._view._ddAlbum.value
        if albumId is None:
            self._view.txt_result.controls.append(ft.Text("Selezionare un album", color="red"))
            self._view.update_page(); return
        try:
            k = int(self._view._txtBrani.value)
        except (ValueError, TypeError):
            self._view.txt_result.controls.append(ft.Text("Inserire numero brani valido", color="red"))
            self._view.update_page(); return
        comp = self._model.getComponenteAlbum(albumId)
        risultati = self._model.getAlbumConKBrani(comp, k)
        self._view.txt_result.controls.append(
            ft.Text(f"Album nella stessa componente con >= {k} brani:"))
        for n in risultati:
            self._view.txt_result.controls.append(
                ft.Text(f"{n.Title} ({len(n.tracks)} brani)"))
        self._view.update_page()


