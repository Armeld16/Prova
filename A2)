from database.DB_connect import DBConnect
from model.album import Album

class DAO():

    @staticmethod
    def getAllAlbums():
        conn = DBConnect.get_connection()
        cursor = conn.cursor(dictionary=True)
        query = """
            SELECT DISTINCT a.AlbumId, a.Title, a.ArtistId
            FROM Album a, Track t
            WHERE a.AlbumId = t.AlbumId
        """
        cursor.execute(query)
        res = [Album(**row) for row in cursor]
        cursor.close(); conn.close()
        return res

    @staticmethod
    def getTracce(albumId):
        conn = DBConnect.get_connection()
        cursor = conn.cursor(dictionary=True)
        query = """
            SELECT TrackId, GenreId
            FROM Track
            WHERE AlbumId = %s
        """
        cursor.execute(query, (albumId,))
        res = [(row["TrackId"], row["GenreId"]) for row in cursor]
        cursor.close(); conn.close()
        return res

    @staticmethod
    def getArchi():
        conn = DBConnect.get_connection()
        cursor = conn.cursor(dictionary=True)
        query = """
            SELECT DISTINCT t1.AlbumId AS id1, t2.AlbumId AS id2
            FROM Track t1, Track t2
            WHERE t1.GenreId = t2.GenreId
            AND t1.AlbumId < t2.AlbumId
        """
        cursor.execute(query)
        res = [(row["id1"], row["id2"]) for row in cursor]
        cursor.close(); conn.close()
        return res


