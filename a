import networkx as nx
from database.DAO import DAO

class Model:
    def __init__(self):
        self._graph = nx.Graph()
        self._idMap = {}

    def buildGraph(self, y1, y2):
        self._graph.clear()
        self._idMap.clear()
        nodi = DAO.getNodi(y1, y2)
        for n in nodi:
            self._idMap[n.constructorId] = n
        self._graph.add_nodes_from(nodi)
        for c1, c2, peso in DAO.getArchi(y1, y2):
            self._graph.add_edge(self._idMap[c1], self._idMap[c2], weight=peso)

    def graphDetails(self):
        return len(self._graph.nodes), len(self._graph.edges)

    def getTop3Archi(self):
        return sorted(self._graph.edges(data=True),
                      key=lambda x: x[2]["weight"], reverse=True)[:3]

    def getNumeroComponenti(self):
        return nx.number_connected_components(self._graph)

    def getMaggioreOrdinata(self):
        largest = max(nx.connected_components(self._graph), key=len)
        ordinati = sorted(largest,
                          key=lambda n: self._graph.degree(n), reverse=True)
        return [(n, self._graph.degree(n)) for n in ordinati]

    def fillDD(self):
        return DAO.getAllYears()

