from database.DB_connect import DBConnect
from model.constructor import Constructor

class DAO():

    @staticmethod
    def getAllYears():
        conn = DBConnect.get_connection()
        cursor = conn.cursor(dictionary=True)
        query = "SELECT DISTINCT year FROM seasons ORDER BY year"
        cursor.execute(query)
        res = [row["year"] for row in cursor]
        cursor.close(); conn.close()
        return res

    @staticmethod
    def getNodi(y1, y2):
        conn = DBConnect.get_connection()
        cursor = conn.cursor(dictionary=True)
        query = """
            SELECT DISTINCT c.constructorId, c.constructorRef, c.name, c.nationality, c.url
            FROM constructors c, results r, races ra
            WHERE c.constructorId = r.constructorId
            AND r.raceId = ra.raceId
            AND ra.year BETWEEN %s AND %s
            AND r.position IS NOT NULL
        """
        cursor.execute(query, (y1, y2))
        res = [Constructor(**row) for row in cursor]
        cursor.close(); conn.close()
        return res

    @staticmethod
    def getArchi(y1, y2):
        conn = DBConnect.get_connection()
        cursor = conn.cursor(dictionary=True)
        query = """
            SELECT r1.constructorId AS c1, r2.constructorId AS c2,
                   COUNT(DISTINCT r1.driverId) AS peso
            FROM results r1, results r2, races ra1, races ra2
            WHERE r1.driverId = r2.driverId
            AND r1.constructorId < r2.constructorId
            AND r1.raceId = ra1.raceId
            AND r2.raceId = ra2.raceId
            AND ra1.year BETWEEN %s AND %s
            AND ra2.year BETWEEN %s AND %s
            AND r1.position IS NOT NULL
            AND r2.position IS NOT NULL
            GROUP BY c1, c2
        """
        cursor.execute(query, (y1, y2, y1, y2))
        res = [(row["c1"], row["c2"], row["peso"]) for row in cursor]
        cursor.close(); conn.close()
        return res



