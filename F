import networkx as nx
from database.DAO import DAO

class Model:
    def __init__(self):
        self._graph = nx.Graph()
        self._idMap = {}

    def buildGraph(self, v1, v2):
        self._graph.clear()
        self._idMap.clear()
        nodi = DAO.getNodi(v1, v2)
        for n in nodi:
            self._idMap[n.id] = n
        self._graph.add_nodes_from(nodi)
        for id1, id2, peso in DAO.getArchi(v1, v2):
            if id1 in self._idMap and id2 in self._idMap:
                self._graph.add_edge(self._idMap[id1], self._idMap[id2], weight=peso)

    def graphDetails(self):
        return len(self._graph.nodes), len(self._graph.edges)

    def getTop5Archi(self):
        return sorted(self._graph.edges(data=True),
                      key=lambda x: x[2]["weight"], reverse=True)[:5]

    def getNumeroComponenti(self):
        return nx.number_connected_components(self._graph)

    def getMaggioreComponente(self):
        return max(nx.connected_components(self._graph), key=len)

    def getVoti(self):
        return DAO.getVoti()


