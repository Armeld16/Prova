import flet as ft

class Controller:
    def __init__(self, view, model):
        self._view = view
        self._model = model

    def handleCreaGrafo(self, e):
        v1 = self._view._ddVoto1.value
        v2 = self._view._ddVoto2.value
        if v1 is None:
            self._view.txt_result.controls.clear()
            self._view.txt_result.controls.append(ft.Text("Selezionare voto minimo", color="red"))
            self._view.update_page(); return
        if v2 is None:
            self._view.txt_result.controls.clear()
            self._view.txt_result.controls.append(ft.Text("Selezionare voto massimo", color="red"))
            self._view.update_page(); return
        if float(v1) > float(v2):
            self._view.txt_result.controls.clear()
            self._view.txt_result.controls.append(ft.Text("Voto min deve essere <= voto max", color="red"))
            self._view.update_page(); return
        self._model.buildGraph(v1, v2)
        nodi, archi = self._model.graphDetails()
        self._view.txt_result.controls.clear()
        self._view.txt_result.controls.append(ft.Text("Grafo correttamente creato:"))
        self._view.txt_result.controls.append(ft.Text(f"Numero di nodi:{nodi}"))
        self._view.txt_result.controls.append(ft.Text(f"Numero di archi:{archi}"))
        top5 = self._model.getTop5Archi()
        self._view.txt_result.controls.append(ft.Text("Top 5 archi:"))
        for a in top5:
            self._view.txt_result.controls.append(
                ft.Text(f"{a[0]} -> {a[1]} : {a[2]['weight']}"))
        n = self._model.getNumeroComponenti()
        self._view.txt_result.controls.append(
            ft.Text(f"Il grafo ha {n} componenti connesse"))
        maggiore = self._model.getMaggioreComponente()
        self._view.txt_result.controls.append(
            ft.Text(f"La più grande componente connessa è lunga {len(maggiore)}:"))
        for nodo in maggiore:
            self._view.txt_result.controls.append(ft.Text(f"{nodo}"))
        self._view.update_page()

    def handleTrovaCammino(self, e):
        pass

    def fillDD(self):
        voti = self._model.getVoti()
        for v in voti:
            self._view._ddVoto1.options.append(ft.dropdown.Option(v))
            self._view._ddVoto2.options.append(ft.dropdown.Option(v))
        self._view.update_page()
