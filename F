from database.DB_connect import DBConnect
from model.actor import Actor

class DAO():

    @staticmethod
    def getVoti():
        conn = DBConnect.get_connection()
        cursor = conn.cursor(dictionary=True)
        query = """SELECT DISTINCT avg_rating
                   FROM ratings
                   ORDER BY avg_rating ASC"""
        cursor.execute(query)
        res = [row["avg_rating"] for row in cursor]
        cursor.close(); conn.close()
        return res

    @staticmethod
    def getNodi(v1, v2):
        conn = DBConnect.get_connection()
        cursor = conn.cursor(dictionary=True)
        query = """
            SELECT DISTINCT n.id, n.name, n.date_of_birth
            FROM names n, role_mapping rm, ratings r
            WHERE n.id = rm.name_id
            AND rm.movie_id = r.movie_id
            AND r.avg_rating BETWEEN %s AND %s
            AND n.date_of_birth IS NOT NULL
        """
        cursor.execute(query, (v1, v2))
        res = [Actor(**row) for row in cursor]
        cursor.close(); conn.close()
        return res

    @staticmethod
    def getArchi(v1, v2):
        conn = DBConnect.get_connection()
        cursor = conn.cursor(dictionary=True)
        query = """
            SELECT rm1.name_id AS id1, rm2.name_id AS id2,
                   SUM(COALESCE(
                       CAST(REPLACE(REPLACE(m.worlwide_gross_income, '$ ', ''), ',', '')
                       AS UNSIGNED), 0)) AS peso
            FROM role_mapping rm1, role_mapping rm2, movie m, ratings r
            WHERE rm1.movie_id = rm2.movie_id
            AND rm1.movie_id = m.id
            AND m.id = r.movie_id
            AND r.avg_rating BETWEEN %s AND %s
            AND rm1.name_id < rm2.name_id
            GROUP BY rm1.name_id, rm2.name_id
        """
        cursor.execute(query, (v1, v2))
        res = [(row["id1"], row["id2"], row["peso"]) for row in cursor]
        cursor.close(); conn.close()
        return res


