from dataclasses import dataclass

@dataclass
class Actor:
    id: str
    name: str
    date_of_birth: str

    def __hash__(self): return hash(self.id)
    def __eq__(self, other): return self.id == other.id
    def __str__(self): return self.name if self.name else ""


